# RPZ Monitor Web GUI configuration
# Copy to /opt/rpz-monitor/.env and adjust values.

# Required: random long secret for session cookies.
# Generate: openssl rand -hex 32
SECRET_KEY=change-this-long-random-secret

# Initial admin account.
# If changing after first run, remove SQLite DB or update user password in DB.
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# SQLite database path.
DB_PATH=/opt/rpz-monitor/data/rpz-monitor.db

# Display/storage timezone for Web GUI timestamps.
APP_TZ=Asia/Jakarta

# RPZ zone name from Kominfo/Komdigi.
RPZ_ZONE=trustpositifkominfo

# BIND statistics channel endpoint.
BIND_STATS_URL=http://127.0.0.1:8053/xml/v3/server

# BIND log files.
QUERY_LOG=/var/cache/bind/query.log
RPZ_LOG=/var/cache/bind/rpz.log

# BIND slave RPZ zone file.
# On Ubuntu BIND may store this in raw/binary format; app does not scan it for domain checks.
ZONE_FILE=/var/cache/bind/db.trustpositifkominfo
